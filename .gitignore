# Local working scratch — not part of the published module.
# docs/      = local design / working notes (not shipped)
# reference/ = upstream nginx source kept locally as a fork reference
# tmp/       = scratch, downloaded sources, and test result logs
docs/
reference/
tmp/

# Downloaded build sources fetched by the test harness
nginx-*/
build/

# nginx/C build artifacts
objs/
*.o
*.so
*.lo
*.la
Makefile

# Test harness runtime
test/logs/
test/*.pid
*.core
core.*

# Editors / OS
.idea/
.vscode/
*.swp
*~
.DS_Store

# Dropbox conflicted copies (this tree lives under Dropbox)
*conflicted copy*

# Debian packaging build artifacts. debian/changelog and debian/control are
# GENERATED at build time (by dch and debian/prepare.sh respectively) — they are
# never committed; debian/control.in is the committed template.
debian/changelog
debian/control
debian/files
debian/.debhelper/
debian/*.substvars
debian/*.debhelper.log
debian/debhelper-build-stamp
debian/libnginx-mod-http-soft-limit-req/
dist/
