#!/bin/sh
# postrm — drop the modules-enabled symlink on remove/purge/disappear so a
# subsequent `nginx -t` (after a `systemctl reload nginx`) doesn't fail with
# "dlopen() failed" referencing the now-deleted .so. Counterpart to postinst's
# symlink-create. The symlink itself lives under /etc/nginx, but we own the
# link, not the target, so `rm -f` is safe across reinstalls.

set -e

case "$1" in
    remove|purge|disappear)
        rm -f /etc/nginx/modules-enabled/50-mod-http-soft-limit-req.conf
        ;;
esac

#DEBHELPER#

exit 0
